{
    "display_information": {
        "name": "Agent Zero",
        "description": "Real-time credential leak detection and remediation for Slack.",
        "background_color": "#16213e"
    },
    "features": {
        "bot_user": {
            "display_name": "Agent Zero",
            "always_online": true
        },
        "slash_commands": [
            {
                "command": "/audit-scan",
                "description": "Scan recent channel history for leaked credentials",
                "should_escape": false
            },
            {
                "command": "/audit-report",
                "description": "Generate a PDF compliance report",
                "should_escape": false
            },
            {
                "command": "/audit-status",
                "description": "Get current compliance metrics",
                "should_escape": false
            },
            {
                "command": "/audit-search",
                "description": "Search flagged incidents",
                "usage_hint": "[topic]",
                "should_escape": false
            }
        ]
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "channels:history",
                "channels:read",
                "chat:write",
                "commands",
                "files:write",
                "users:read",
                "im:write"
            ]
        }
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "message.channels",
                "message.groups",
                "message_changed",
                "member_joined_channel"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "is_hosted": false
    }
}
