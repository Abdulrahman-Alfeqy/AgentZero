# Agent Zero — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# ── Slack ──────────────────────────────────────────────────────────────────────────
# Bot Token (xoxb-) — from your Slack App's "OAuth & Permissions" page
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token (xapp-) — from "Basic Information" > "App-Level Tokens"
# NOT required in HTTP mode (Events API). Only needed if running Socket Mode
# locally for development. Leave blank for all cloud deployments.
SLACK_APP_TOKEN=

# Signing Secret — from "Basic Information" > "App Credentials"
SLACK_SIGNING_SECRET=your-signing-secret-here

# ── Compliance Officer ────────────────────────────────────────────────────────────
# Slack User ID of the compliance officer who receives HIGH-severity DMs and rate limit alerts.
# Leave blank to disable DM notifications.
COMPLIANCE_OFFICER_ID=

# ── AI / Gemini ─────────────────────────────────────────────────────────────────
# Optional: Google Gemini API key for AI-powered semantic detection.
# If left blank, semantic analysis is skipped silently.
GEMINI_API_KEY=

# Optional: Comma-separated list of Gemini API Keys for load balancing.
# If provided, it overrides GEMINI_API_KEY and picks a random key per request.
GEMINI_API_KEYS=

# ── AI Provider Fallback Keys ─────────────────────────────────────────────────
# Optional fallback providers. If Gemini quota is exhausted, tried in order.
# OpenRouter: sign up at openrouter.ai (free, no credit card)
OPENROUTER_API_KEY=

# Groq: sign up at console.groq.com (free)
GROQ_API_KEY=

# GitHub: create token at github.com/settings/tokens (free for any GitHub user)
GITHUB_TOKEN=

# Z.AI / GLM: sign up at open.bigmodel.cn (free tier, 1 concurrent request)
ZAI_API_KEY=

# ── MCP Server ────────────────────────────────────────────────────────────────────
# Port the MCP compliance server listens on (SSE transport)
MCP_SERVER_PORT=5001

# Host the MCP server binds to (default: loopback only)
MCP_SERVER_HOST=0.0.0.0

# ── Flask Dashboard ────────────────────────────────────────────────────────────────
# Host and port for the Flask compliance dashboard
# For cloud deployment (Render), set DASHBOARD_HOST=0.0.0.0
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000

# Render/Fly.io dynamic port. Leave as 5000 for local dev.
PORT=5000

# Optional: Basic Auth for the dashboard
# Dashboard credentials. Must be set before first run.
DASHBOARD_USERNAME=# REQUIRED: set your own dashboard username
DASHBOARD_PASSWORD=# REQUIRED: set your own strong dashboard password

# ── Storage ──────────────────────────────────────────────────────────────────────────
# Path to the append-only incident log (JSON Lines format)
STORAGE_PATH=incidents.jsonl

# Directory where generated PDF reports are saved
REPORTS_DIR=reports

# ── Slack OAuth Scopes Required ─────────────────────────────────────────────────
# Bot Token Scopes:
#   channels:history     — read message history for /audit-scan
#   channels:read        — resolve channel names
#   chat:write           — post ephemeral messages
#   commands             — register and respond to slash commands
#   files:write          — upload PDF reports
#   users:read           — resolve usernames
#   app_mentions:read    — (optional) respond to @mentions
# /audit-search uses local incident log — no Slack search scopes needed
